# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# Bedrock Model (default: amazon.nova-pro-v1:0)
BEDROCK_MODEL_ID=amazon.nova-pro-v1:0

# Cognito (optional — disables auth if not set)
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Database (optional — defaults to SQLite at data/checkpoints.db)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Storage
WILLIAM_S3_BUCKET=william-output

# GitHub (for Scout's web research — optional)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# SAM.gov API (for Scout's contract search)
SAM_API_KEY=your_sam_gov_api_key

# Bonfire API (for Scout's bid search — optional)
BONFIRE_API_KEY=your_bonfire_api_key
